# CarePulse Environment Configuration

# Operating Mode
USE_MOCK=true

# Nokia Network as Code API
# Get your API token from: https://networkascode.nokia.io
NOKIA_API_TOKEN=your_nokia_api_token_here
NOKIA_ORG_ID=your_organization_id_here

# Google Gemini API
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://carepulse:carepulse@localhost/carepulse

# For local development with SQLite
# DATABASE_URL=sqlite:///./carepulse.db
